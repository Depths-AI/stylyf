{
  "version": "1.0",
  "app": {
    "name": "Stylyf Builder",
    "kind": "internal-tool",
    "description": "An auth-gated internal AI app factory for generating, previewing, testing, and git-tracking SolidStart apps with Stylyf, Codex, and Webknife."
  },
  "backend": {
    "mode": "hosted"
  },
  "media": {
    "mode": "basic"
  },
  "experience": {
    "theme": "opal",
    "mode": "light",
    "radius": "trim",
    "density": "comfortable",
    "spacing": "tight"
  },
  "actors": [
    {
      "name": "Admin",
      "kind": "admin",
      "description": "Depths AI operator with access to all internal builder projects."
    },
    {
      "name": "Builder",
      "kind": "user",
      "description": "Authenticated team member creating and refining app drafts."
    }
  ],
  "objects": [
    {
      "name": "projects",
      "table": "projects",
      "label": "Projects",
      "purpose": "Builder-owned generated app workspaces tracked through GitHub handoff.",
      "ownership": "user",
      "visibility": "private",
      "access": {
        "list": "user",
        "read": "owner",
        "create": "user",
        "update": "owner",
        "delete": "owner"
      },
      "fields": [
        {
          "name": "name",
          "label": "Project name",
          "type": "short-text",
          "required": true,
          "indexed": true
        },
        {
          "name": "slug",
          "type": "slug",
          "required": true,
          "unique": true
        },
        {
          "name": "status",
          "type": "status",
          "required": true,
          "options": [
            "draft",
            "generating",
            "ready",
            "error",
            "archived"
          ],
          "default": "draft"
        },
        {
          "name": "summary",
          "type": "long-text"
        },
        {
          "name": "workspacePath",
          "type": "short-text"
        },
        {
          "name": "previewUrl",
          "type": "short-text"
        },
        {
          "name": "githubRepoFullName",
          "type": "short-text"
        },
        {
          "name": "lastPushedSha",
          "type": "short-text"
        }
      ]
    },
    {
      "name": "agent_events",
      "table": "agent_events",
      "label": "Agent events",
      "purpose": "Persisted builder timeline entries for chat, commands, approvals, checks, visual QA, commits, pushes, and handoff state.",
      "ownership": "user",
      "visibility": "private",
      "access": {
        "list": "owner",
        "read": "owner",
        "create": "owner",
        "update": "owner",
        "delete": "owner"
      },
      "fields": [
        {
          "name": "type",
          "type": "short-text",
          "required": true,
          "indexed": true
        },
        {
          "name": "payload",
          "type": "json"
        }
      ]
    }
  ],
  "surfaces": [
    {
      "name": "Projects",
      "kind": "list",
      "object": "projects",
      "path": "/",
      "audience": "user",
      "title": "Projects"
    },
    {
      "name": "New Project",
      "kind": "create",
      "object": "projects",
      "path": "/projects/new",
      "audience": "user",
      "title": "New project"
    },
    {
      "name": "Project Workbench",
      "kind": "detail",
      "object": "projects",
      "path": "/projects/:id",
      "audience": "user",
      "title": "Project workbench"
    },
    {
      "name": "Settings",
      "kind": "settings",
      "path": "/settings",
      "audience": "user",
      "title": "Settings"
    }
  ],
  "navigation": {
    "primary": [
      {
        "label": "Projects",
        "href": "/",
        "auth": "user"
      },
      {
        "label": "New Project",
        "href": "/projects/new",
        "auth": "user"
      },
      {
        "label": "Settings",
        "href": "/settings",
        "auth": "user"
      }
    ],
    "userMenu": [
      {
        "label": "Sign out",
        "href": "/api/auth/sign-out",
        "auth": "user"
      }
    ]
  },
  "deployment": {
    "profile": "none"
  }
}
