{
  "app": {
    "name": "Stylyf Builder",
    "kind": "internal-tool"
  },
  "backend": {
    "mode": "hosted",
    "auth": "supabase",
    "data": "supabase sdk",
    "storage": "tigris/s3-compatible"
  },
  "resources": [
    "projects",
    "agent_events"
  ],
  "workflows": [],
  "routes": [
    {
      "path": "/",
      "page": "resource-index",
      "resource": "projects",
      "bindings": [],
      "file": "src/routes/index.tsx"
    },
    {
      "path": "/projects",
      "page": "resource-index",
      "resource": "projects",
      "bindings": [],
      "file": "src/routes/projects/index.tsx"
    },
    {
      "path": "/projects/new",
      "page": "resource-create",
      "resource": "projects",
      "bindings": [],
      "file": "src/routes/projects/new.tsx"
    },
    {
      "path": "/projects/:id/edit",
      "page": "resource-edit",
      "resource": "projects",
      "bindings": [],
      "file": "src/routes/projects/[id]/edit.tsx"
    },
    {
      "path": "/agent-events",
      "page": "resource-index",
      "resource": "agent_events",
      "bindings": [],
      "file": "src/routes/agent-events/index.tsx"
    },
    {
      "path": "/agent-events/new",
      "page": "resource-create",
      "resource": "agent_events",
      "bindings": [],
      "file": "src/routes/agent-events/new.tsx"
    },
    {
      "path": "/agent-events/:id/edit",
      "page": "resource-edit",
      "resource": "agent_events",
      "bindings": [],
      "file": "src/routes/agent-events/[id]/edit.tsx"
    },
    {
      "path": "/settings",
      "page": "settings",
      "bindings": [],
      "file": "src/routes/settings.tsx"
    },
    {
      "path": "/projects/:id",
      "page": "resource-detail",
      "resource": "projects",
      "bindings": [],
      "file": "src/routes/projects/[id]/index.tsx"
    }
  ],
  "files": [
    ".env.example",
    "app.config.ts",
    "package.json",
    "src/app.css",
    "src/app.tsx",
    "src/lib/attachments.ts",
    "src/lib/auth.ts",
    "src/lib/env.ts",
    "src/lib/resources.ts",
    "src/lib/server/attachments.ts",
    "src/lib/server/resource-policy.ts",
    "src/lib/storage.ts",
    "src/lib/supabase-browser.ts",
    "src/lib/supabase.ts",
    "src/routes/agent-events/[id]/edit.tsx",
    "src/routes/agent-events/index.tsx",
    "src/routes/agent-events/new.tsx",
    "src/routes/api/attachments/confirm.ts",
    "src/routes/api/attachments/delete.ts",
    "src/routes/api/attachments/intent.ts",
    "src/routes/api/attachments/replace.ts",
    "src/routes/auth/callback.ts",
    "src/routes/index.tsx",
    "src/routes/login.tsx",
    "src/routes/projects/[id]/edit.tsx",
    "src/routes/projects/[id]/index.tsx",
    "src/routes/projects/index.tsx",
    "src/routes/projects/new.tsx",
    "src/routes/settings.tsx",
    "stylyf.plan.json",
    "stylyf.spec.json",
    "supabase/policies.sql",
    "supabase/schema.sql"
  ],
  "postGenerateSteps": []
}
